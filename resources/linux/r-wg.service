[Unit]
Description=r-wg privileged backend
After=network-online.target
Wants=network-online.target
Requires=r-wg.socket

[Service]
Type=simple
ExecStart=/usr/local/libexec/r-wg/r-wg --linux-service --socket-group r-wg
Restart=on-failure
RestartSec=1
RuntimeDirectory=r-wg
RuntimeDirectoryMode=0755
NoNewPrivileges=yes
